# --- ACE modes ---
ACE_ENABLE_FULL_MODE=1
ACE_SESSION_HMAC_SECRET=PASTE_A_LONG_RANDOM_SECRET_HERE

# --- Rate limits (optional) ---
ACE_CHAT_RPM=30
ACE_FULL_CHAT_RPM=6
ACE_LOGIN_RPM=12
ACE_SIGNUP_RPM=6

# --- 2FA on login ---
ACE_2FA_ENABLED=1
ACE_2FA_OTP_TTL_SECONDS=600
ACE_2FA_CODE_LENGTH=6
ACE_2FA_MAX_ATTEMPTS=6

# --- SMTP (required for 2FA email) ---
ACE_SMTP_HOST=smtp.yourprovider.com
ACE_SMTP_PORT=587
ACE_SMTP_USER=your_email@domain.com
ACE_SMTP_PASS=your_smtp_password_or_app_password
ACE_SMTP_FROM=ACE <your_email@domain.com>
ACE_SMTP_TLS=1
ACE_SMTP_SSL=0